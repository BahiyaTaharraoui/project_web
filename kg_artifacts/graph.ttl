@prefix ex: <http://myolympicgraph.org/resource/> .
@prefix ont: <http://myolympicgraph.org/ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ont:Organization a rdfs:Class,
        owl:Class ;
    rdfs:comment "A committee, federation, club or institution"@en ;
    rdfs:subClassOf owl:Thing .

ont:Person a rdfs:Class,
        owl:Class ;
    rdfs:comment "A human being mentioned in the Olympic context"@en ;
    rdfs:subClassOf owl:Thing .

ont:Place a rdfs:Class,
        owl:Class ;
    rdfs:comment "A geopolitical entity: city, country or region"@en ;
    rdfs:subClassOf owl:Thing .

ont:basedIn a owl:ObjectProperty ;
    rdfs:label "based in"@en ;
    rdfs:comment "A person is associated with a geopolitical location"@en ;
    rdfs:domain ont:Person ;
    rdfs:range ont:Place .

ont:locatedIn a owl:ObjectProperty ;
    rdfs:label "located in"@en ;
    rdfs:comment "An organization is located in a place"@en ;
    rdfs:domain ont:Organization ;
    rdfs:range ont:Place .

ont:memberOf a owl:ObjectProperty ;
    rdfs:label "member of"@en ;
    rdfs:comment "A person is affiliated with an organization"@en ;
    rdfs:domain ont:Person ;
    rdfs:range ont:Organization .

ont:mentionedIn a owl:DatatypeProperty ;
    rdfs:label "mentioned in"@en ;
    rdfs:comment "Source Wikipedia page where the entity was extracted"@en .

